# Required
DISCORD_TOKEN=your_bot_token_here

# Optional: numeric role ID to use instead of RELIABLE_ROLE_NAME in code
RELIABLE_ROLE_ID=

# Optional: numeric role ID to use instead of TRUSTED_ROLE_NAME in code
TRUSTED_ROLE_ID=

# Optional: directory for runtime data files (SQLite + JSON state)
# Docker image/compose default: /data
RESHUFFLE_DATA_DIR=

# Optional: path to editable JSON question list
# Default: questions.json inside RESHUFFLE_DATA_DIR
QUESTION_BANK_FILE=
